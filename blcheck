# Bash setup {
#set -o pipefail  # trace ERR through pipes
set -o errtrace  # trace ERR through 'time command' and other functions
set -o nounset   ## set -u : exit the script if you try to use an uninitialised variable
set -o errexit   ## set -e : exit the script if any statement returns a non-true return value

function cleanup() {
	rm -f "${COUNT_FILE}" "${COUNT_FILE}.lock" "${JSON_FILE}"
	rmdir "${COUNT_FILE}.lock.d" 2>/dev/null || true
}

function handleError() {
	cleanup
	error "Command was interrupted."
}
trap "handleError" SIGHUP SIGINT SIGQUIT SIGABRT SIGTERM

#~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ }

# Config {

    pushd "$(dirname "$0")" >/dev/null
    SCRIPT_PATH=$(pwd -P)
    popd >/dev/null

    # How many tries and for how long to wait for DNS queries
    CONF_DNS_TRIES=2
    CONF_DNS_DURATION=3

    CONF_LIST_FILE="${SCRIPT_PATH}/list.default"

    # How many dig/host processes to run in parallel (default: 75% of cores).
    # Can be overridden with -j: a fixed number (e.g. 6) or a core percentage (e.g. 50%).
    CONF_USE_OF_CORES="75%"

    if [ "$(uname)" != "Darwin" ]; then
        OS="linux"
    else
        OS="macos"
    fi

#~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ }


# Definitions {

    COUNT_FILE=/tmp/blcheck.$$
    JSON_FILE=/tmp/blcheck.$$.json

    # Common regular expressions
    REGEX_IP='\([0-9]\{1,3\}\)\.\([0-9]\{1,3\}\)\.\([0-9]\{1,3\}\)\.\([0-9]\{1,3\}\)'
    REGEX_IP6='^([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}$'
    REGEX_DOMAIN='\([a-zA-Z0-9]\+\(-[a-zA-Z0-9]\+\)*\.\)\+[a-zA-Z]\{2,\}'
    REGEX_LIST='^[ \\t]*([^=#]+)(=(([^#])+))?(#(DNSBL|DNSWL|URIBL))?[ \\t]*$'

    # Colors
    if [[ $- == *i* ]]; then
        RED=$(tput setaf 1)
        GREEN=$(tput setaf 2)
        YELLOW=$(tput setaf 3)
        CLEAR=$(tput sgr0)
    else
        RED=$(tput -T xterm setaf 1)
        GREEN=$(tput -T xterm setaf 2)
        YELLOW=$(tput -T xterm setaf 3)
        CLEAR=$(tput -T xterm sgr0)
    fi

    # Define spinner
    SPINNER="-\|/"
    #SPINNER=".oO@*"
    #SPINNER="▉▊▋▌▍▎▏▎▍▌▋▊▉"
    #SPINNER="←↖↑↗→↘↓↙"
    #SPINNER="▁▂▃▄▅▆▇█▇▆▅▄▃▁"
    #SPINNER="▖▘▝▗"
    #SPINNER="┤┘┴└├┌┬┐"
    #SPINNER="◢◣◤◥"
    #SPINNER="◰◳◲◱"
    #SPINNER="◴◷◶◵"
    #SPINNER="◐◓◑◒"

    DNSSERVER=
    DOMAIN=
    PLAIN=
    VERBOSE=0
    VERIFY_BL=
    OUTPUT_FORMAT=text

#~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ }

# Macros {

    # Expand an IPv6 address to 32 lowercase hex digits (no colons or separators),
    # suitable for nibble-reversal used in DNSBL lookups.
    function expand_ipv6() {
        local addr
        addr=$(tr '[:upper:]' '[:lower:]' <<< "$1")

        # Expand :: notation by counting groups on each side and inserting zero groups
        if [[ "${addr}" == *::* ]]; then
            local left="${addr%%::*}"
            local right="${addr##*::}"
            local lgroups=0 rgroups=0
            [[ -n "${left}" ]]  && lgroups=$(( $(tr -cd ':' <<< "${left}"  | wc -c) + 1 ))
            [[ -n "${right}" ]] && rgroups=$(( $(tr -cd ':' <<< "${right}" | wc -c) + 1 ))
            local fill
            fill=$(printf '0:%.0s' $(seq 1 $(( 8 - lgroups - rgroups ))))
            fill="${fill%:}"
            addr="${left:+${left}:}${fill}${right:+:${right}}"
        fi

        # Pad each group to 4 hex digits and concatenate
        tr ':' '\n' <<< "${addr}" | while IFS= read -r g; do
            printf "%04x" "$((16#${g:-0}))"
        done | tr -d '\n'
    }

    # Verbose printing
    function info() {
        if [[ ${VERBOSE} -ge "$1" ]]; then
            echo "$2"
        fi
    }

    # Error handling
    function error() {
        echo "ERROR: $1" >&2
        exit 2
    }

    # Show progress
    function progress() {
        local completed=$1

        # Bar
        local x=$((${completed} % ${#SPINNER} + 1))
        local BAR
        BAR=$(echo ${SPINNER} | awk "{ print substr(\$0, ${x}, 1) }")
        if [[ -z "${PLAIN}" ]]; then
            printf "\r ";
        fi

        # BAR as printf arg so that backslash will be literally interpreted
        printf "[ %s %3s%% ] checking... %4s / $2  \r" "${BAR}" $((${completed} * 100 / $2)) "${completed}";
    }

    # Resolve the IP
    function resolve() {
        local type=${2:-a}

        # IPv4 passthrough
        local IP
        IP=$(echo "$1" | grep "^${REGEX_IP}$") || true
        if [[ "${IP}" ]]; then
            echo "${IP}"

        # IPv6 passthrough
        elif [[ "$1" =~ ${REGEX_IP6} ]]; then
            echo "$1"

        # Resolve domain
        else

            # Handle special resolve types
            case "${type}" in
                "ns" ) TYPE="ns"; REGEX="${REGEX_DOMAIN}\.$";;
                   * ) TYPE="a";  REGEX="${REGEX_IP}$";;
            esac

            case "${CMD}" in
                ${CMD_DIG} ) "${CMD}" ${DNSSERVER} +short -t "${TYPE}" +time=${CONF_DNS_DURATION} +tries=${CONF_DNS_TRIES} "$1" | grep -om 1 "${REGEX}";;
                ${CMD_HOST} ) "${CMD}" -t "${TYPE}" -W ${CONF_DNS_DURATION} -R ${CONF_DNS_TRIES} "$1" ${DNSSERVER} | tail -n1 | grep -om 1 "${REGEX}";;
            esac
        fi
    }

    # Result info for IP
    function text() {
        # IP already?
        local IP
        IP=$(echo "$1" | grep "^${REGEX_IP}$") || true
        if [[ -n "${IP}" ]]; then
            echo "${IP}"

        # Resolve domain
        else

            local TYPE="txt"
            case "${CMD}" in
                ${CMD_DIG} ) "${CMD}" ${DNSSERVER} +short -t "${TYPE}" +time=${CONF_DNS_DURATION} +tries=${CONF_DNS_TRIES} "$1" ;;
                ${CMD_HOST} ) "${CMD}" -t "${TYPE}" -W ${CONF_DNS_DURATION} -R ${CONF_DNS_TRIES} "$1" ${DNSSERVER} | tail -n1 ;;
            esac
        fi
    }

    # Write a JSONL entry when JSON output is enabled
    function json_entry() {
        if [[ "${OUTPUT_FORMAT}" == "json" ]]; then
            local list="$1" type="$2" status="$3" response="${4:-}" txt="${5:-}"
            # Escape double quotes in values
            response="${response//\"/\\\"}"
            txt="${txt//\"/\\\"}"
            printf '{"list":"%s","type":"%s","status":"%s","response":"%s","txt":"%s"}\n' \
                "${list}" "${type}" "${status}" "${response}" "${txt}" >>"${JSON_FILE}"
        fi
    }

    # Check domain/IP against a single list entry
    function check() {
        local I=$1
        local BL=$2

        local PREFIX=
        I=$((I + 1))

        # Parse list entry
        if [[ ! ${BL} =~ ${REGEX_LIST} ]]; then
            error "List entry ${BL} broken"
        fi
        local DOMAIN="${BASH_REMATCH[1]}"
        local FILTER="${BASH_REMATCH[3]}"
        local TYPE="${BASH_REMATCH[6]}"



        # What should we test
        if [[ "${TYPE}" != "URIBL" ]]; then
            # IP based test
            local TEST="${REVERSED}.${DOMAIN}."
        else
            # Domain name based test (URI)
            local TEST="${TARGET}.${DOMAIN}."
        fi


        # Make sure the info is shown if we are checking the servers
        if [[ "${VERIFY_BL}" && "${VERBOSE}" -lt 1 ]]; then
            local VERBOSE=1
        fi

        # Get the status
        local RESPONSE
        RESPONSE=$(resolve "${TEST}")

        # output has to be thread-safe
        (
            if [[ "${OS}" == "linux" ]]; then
                flock -x 9
            else
                # macOS has no flock; use mkdir as a portable lock
                while ! mkdir "${COUNT_FILE}.lock.d" 2>/dev/null; do
                    sleep 0.01
                done
                trap 'rmdir "${COUNT_FILE}.lock.d" 2>/dev/null' EXIT
            fi

            # For verbose output
            if [[ "${VERBOSE}" -ge 1 ]]; then

                # Show percentage
                local STATUS=$(( $(wc -l < "${COUNT_FILE}") + 1 ))
                STATUS=$(printf " %3s" "$((${STATUS} * 100 / ${COUNT} ))")
                STATUS="${STATUS}% "

                # Show additional info
                if [[ "${VERBOSE}" -ge 3 ]]; then
                    PREFIX=$(printf "%-60s" "${TEST}")
                else
                    PREFIX=$(printf "%-50s" "${DOMAIN}")
                fi

                PREFIX="${STATUS} ${PREFIX}"
                if [[ -z "${PLAIN}" ]]; then
                    printf "%s \b" "${PREFIX}"
                fi
            fi

            # Not blocklisted
            if [[ -z "${RESPONSE}" ]]; then

                # Optionally verify the list is still reachable (-c flag)
                ERROR=""
                if [[ "${VERIFY_BL}" ]]; then
                    local TDL
                    TDL=$(echo "${DOMAIN}" | grep -om 1 '\([a-zA-Z0-9]\+\(-[a-zA-Z0-9]\+\)*\.\)[a-zA-Z]\{2,\}$')
                    if [[ ! "$(resolve "${TDL}" ns)" ]]; then
                        if [[ -z "${PLAIN}" ]]; then printf "\r"; fi
                        printf "%s%sunreachable server%s\n" "${YELLOW}" "${PREFIX}" "${CLEAR}";
                        echo "I" >>"${COUNT_FILE}"
                        json_entry "${DOMAIN}" "${TYPE}" "unreachable" "" ""
                        ERROR=TRUE
                    fi
                fi

                if [[ ! "${ERROR}" ]]; then
                    if [[ -n "${VERIFY_BL}" || "${VERBOSE}" -ge 1 ]]; then
                        if [[ -z "${PLAIN}" ]]; then printf "\r"; fi
                        printf "%s%s✓%s\n" "${CLEAR}" "${PREFIX}" "${CLEAR}";
                    fi
                    echo "P" >>"${COUNT_FILE}"
                    json_entry "${DOMAIN}" "${TYPE}" "pass" "" ""
                fi;

            # Invalid response
            elif [[ ! "${RESPONSE}" =~ ${FILTER} ]]; then
                if [[ "${VERBOSE}" -ge 1 ]]; then
                    if [[ -z "${PLAIN}" ]]; then printf "\r"; fi
                    printf "%s%sinvalid response (%s)%s\n" "${YELLOW}" "${PREFIX}" "${RESPONSE}" "${CLEAR}";
                    printf "%s%${#PREFIX}s%s%s\n" "${YELLOW}" "TXT: " "$(text "${TEST}")" "${CLEAR}";
                fi;
                echo "I" >>"${COUNT_FILE}"
                json_entry "${DOMAIN}" "${TYPE}" "invalid" "${RESPONSE}" ""

            # matched
            else
                if [[ "${TYPE}" != "DNSWL" ]]; then
                    if [[ "${VERBOSE}" -ge 1 ]]; then
                        if [[ -z "${PLAIN}" ]]; then printf "\r"; fi
                        printf "%s%sblocklisted (%s)%s\n" "${RED}" "${PREFIX}" "${RESPONSE}" "${CLEAR}";
                        printf "%s%${#PREFIX}s%s%s\n" "${RED}" "TXT: " "$(text "${TEST}")" "${CLEAR}";
                    elif [[ "${VERBOSE}" -ge 0 ]]; then
                        if [[ -z "${PLAIN}" ]]; then printf "\r                                                          "; printf "\r"; fi
                        printf "%s%s%s : %s\n" "${RED}" "${DOMAIN}" "${CLEAR}" "${RESPONSE}"
                    fi
                    echo "F" >>"${COUNT_FILE}"
                    json_entry "${DOMAIN}" "${TYPE}" "blocklisted" "${RESPONSE}" "$(text "${TEST}")"
                else
                    if [[ "${VERBOSE}" -ge 1 ]]; then
                        if [[ -z "${PLAIN}" ]]; then printf "\r"; fi
                        printf "%s%sallowlisted (%s)%s\n" "${GREEN}" "${PREFIX}" "${RESPONSE}" "${CLEAR}";
                        printf "%s%${#PREFIX}s%s%s\n" "${GREEN}" "TXT: " "$(text "${TEST}")" "${CLEAR}";
                    elif [[ "${VERBOSE}" -ge 0 ]]; then
                        if [[ -z "${PLAIN}" ]]; then printf "\r                                                          "; printf "\r"; fi
                        printf "%s%s%s : %s\n" "${GREEN}" "${DOMAIN}" "${CLEAR}" "${RESPONSE}"
                    fi
                    echo "W" >>"${COUNT_FILE}"
                    json_entry "${DOMAIN}" "${TYPE}" "allowlisted" "${RESPONSE}" "$(text "${TEST}")"
                fi
            fi
            if [[ "${VERBOSE}" -ge 0 ]]; then
                if [[ -z "${PLAIN}" ]]; then
                    progress "$(wc -l < "${COUNT_FILE}")" "${COUNT}"
                fi
            fi
        ) 9>"${COUNT_FILE}.lock"
    }

    # Load list from file
    function loadList() {

        # Make sure the file is readable
        if [[ -z "$1" ]]; then
            error "Option -l requires an additional parameter";
        elif [[ ! -r $1 ]]; then
            error "File $1 cannot be opened for reading, make sure it exists and that you have appropriate privileges"
        fi

        # Ignore commented and empty lines
        CONF_LISTS=$(grep -vE "^(#|$)" "$1")
    }

    # Show help
    function showHelp() {
        cat <<HELP
blcheck [options] <domain_or_IP>

Supplied domain must be a fully qualified domain name.
If an IP (v4 or v6) is supplied, the PTR check cannot be executed and will be skipped.

-d dnshost  Use host as DNS server to make lookups
-l file     Load lists from file with one entry per line
-c          Warn if the top level domain of the list has expired
-v          Verbose mode, can be used multiple times (up to -vvv)
-q          Quiet mode with absolutely no output (useful for scripts)
-p          Plain text output (no coloring, no interactive status)
-j          JSON output (implies -p)
-t          Thread numbers (4) or percentage (75%) of cores to use
-h          The help you are just reading

Result of the script is the number of blocklisted entries. So if the supplied
IP is not blocklisted on any of the servers the return code is 0.

HELP
        exit;
    }

#~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ ~ }

# Parse the params
while getopts :vqphjcl:t:d: arg; do
    case "${arg}" in
        d) DNSSERVER="${OPTARG}";;
        l) CONF_LIST_FILE="${OPTARG}";;
        c) VERIFY_BL=TRUE;;
        v) VERBOSE=$((VERBOSE + 1));;
        q) VERBOSE=-1;;
        p) PLAIN=1 RED="" GREEN="" YELLOW="" CLEAR="" ;;
        j) OUTPUT_FORMAT=json PLAIN=1 RED="" GREEN="" YELLOW="" CLEAR="" ;;
        t) CONF_USE_OF_CORES="${OPTARG}";;
        h) showHelp;;
        ?) error "Unknown option ${OPTARG}";;
    esac
done
shift $((OPTIND - 1))

# load list
loadList "${CONF_LIST_FILE}"

# Get the domain
if [[ $# -eq 0 ]]; then
    echo "Missing target domain or IP."
    showHelp
fi
TARGET=$1

# Some shells disable parsing backslash in echo statements by default
# Set the flag to enable echo to behave consistently across platforms
shopt -s xpg_echo

# Get the command we will use: dig or host
CMD_DIG=$(command -v dig)
if [[ "${CMD_DIG}" ]]; then
    if [[ -n "${DNSSERVER}" ]]; then
        DNSSERVER="@${DNSSERVER}"
    fi
    CMD=${CMD_DIG}
else
    CMD_HOST=$(command -v host)
    if [[ "${CMD_HOST}" ]]; then
        CMD=${CMD_HOST}
    fi
fi
if [[ -z "${CMD}" ]]; then
    error "Either dig or host command is required."
fi
info 3 "Using ${CMD} to resolve DNS queries"

# Parse IP
IP=$(resolve "${TARGET}")
if [[ -z "${IP}" ]]; then
    error "No DNS record found for ${TARGET}"
elif [[ "${IP}" =~ ${REGEX_IP6} ]]; then
    info 3 "Using ${TARGET} for target (IPv6)"
    TARGET_TYPE="ipv6"
elif [[ "${IP}" != "${TARGET}" ]]; then
    DOMAIN=${TARGET}
    info 2 "Using ${TARGET} for target, resolved to ${IP}"
    TARGET_TYPE="domain"
else
    info 3 "Using ${TARGET} for target"
    TARGET_TYPE="ip"
fi

# Reverse the IP for DNSBL lookups
if [[ "${TARGET_TYPE}" == "ipv6" ]]; then
    # Expand to 32 hex digits, reverse each nibble, dot-separate
    REVERSED=$(expand_ipv6 "${IP}" | rev | sed 's/./&./g; s/\.$//')
else
    REVERSED=$(echo "${IP}" | sed -ne "s~^${REGEX_IP}$~\4.\3.\2.\1~p")
fi
info 3 "Using ${REVERSED} for reversed IP"

# Get the PTR
info 3 "Checking the PTR record"
case "${CMD}" in
    ${CMD_DIG} ) PTR=$("${CMD}" ${DNSSERVER} +short -x "${IP}" | sed s/\.$//);;
    ${CMD_HOST} ) PTR=$("${CMD}" "${IP}" ${DNSSERVER} | tail -n1 | grep -o '[^ ]\+$' | sed s/\.$//)
esac

# Validate PTR
if [[ -z "${PTR}" ]]; then
    info 0 "${YELLOW}Warning: PTR lookup failed${CLEAR}"

else

    # Match against supplied domain
    info 1 "PTR resolves to ${PTR}"
    if [[ -n "${DOMAIN}" ]]; then
        if [[ "${DOMAIN}" != "${PTR}" ]]; then
            info 0 "${YELLOW}Warning: PTR record does not match supplied domain: ${TARGET} != ${PTR}${CLEAR}"
        else
            info 1 "${GREEN}PTR record matches supplied domain ${PTR}${CLEAR}"
        fi
    fi
fi

# Filter out the blocklists
BLOCKLISTS=""
COUNT_DNSBL=0
COUNT_DNSWL=0
COUNT_URIBL=0
COUNT=0
for BL in ${CONF_LISTS}; do
    if [[ "${BL}" ]]; then
        if [[ ${BL} =~ ${REGEX_LIST} ]]; then
            DOMAIN="${BASH_REMATCH[1]}"
            if [[ -n "${BASH_REMATCH[3]}" ]]; then
                FILTER="${BASH_REMATCH[3]}"
            else
                FILTER='127\.([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})'
            fi
            if [[ -n "${BASH_REMATCH[6]}" ]]; then
                TYPE="${BASH_REMATCH[6]}"
            else
                TYPE='DNSBL'
            fi

            # Make sure the domain is a proper one
            TMP=$(echo "${DOMAIN}" | sed -e 's/^[ \t]*//' | grep ^"${REGEX_DOMAIN}"$)
            if [[ -z "${TMP}" ]]; then
               info 0 "${YELLOW}Warning: domain '${DOMAIN}' is not valid and will be ignored${CLEAR}"

            else
                if [[ ( "${TARGET_TYPE}" == 'ip' || "${TARGET_TYPE}" == 'ipv6' ) && "${TYPE}" == 'URIBL' ]]; then
                    info 0 "${GREEN}Notice: URIBL entry '${DOMAIN}' will be ignored, because ${TARGET} is an IP address${CLEAR}"
                else
                    case "${TYPE}" in
                        "DNSBL") COUNT_DNSBL=$((COUNT_DNSBL + 1)) ;;
                        "DNSWL") COUNT_DNSWL=$((COUNT_DNSWL + 1)) ;;
                        "URIBL") COUNT_URIBL=$((COUNT_URIBL + 1)) ;;
                    esac
                    COUNT=$((COUNT + 1))

                    # It is a proper blocklist
                    if [[ "${BLOCKLISTS}" ]]; then
                        BLOCKLISTS=$(echo "${BLOCKLISTS}\n${DOMAIN}=${FILTER}#${TYPE}")
                    else
                        BLOCKLISTS="${DOMAIN}=${FILTER}#${TYPE}"
                    fi
                fi
            fi
        else
            info 0 "${YELLOW}Warning: list entry '${BL}' is not valid and will be ignored${CLEAR}"
        fi
    fi
done

# Make sure we have at least one list entry
if [[ "${COUNT}" -eq 0 ]]; then
    error "No lists have been specified"
fi
info 1 "Matching against ${COUNT} entries:"
info 1 "  - ${COUNT_DNSBL} DNS blocklists"
info 1 "  - ${COUNT_DNSWL} DNS allowlists"
info 1 "  - ${COUNT_URIBL} URI blocklists"

# Iterate over all list entries
touch "${COUNT_FILE}"
export -f check info error resolve text progress expand_ipv6 json_entry
export REGEX REGEX_LIST REGEX_IP REGEX_IP6 REGEX_DOMAIN
export CLEAR YELLOW RED GREEN SPINNER OS
export REVERSED TARGET VERIFY_BL VERBOSE PLAIN COUNT COUNT_FILE JSON_FILE OUTPUT_FORMAT
export CMD_DIG CMD_HOST CMD DNSSERVER CONF_DNS_DURATION CONF_DNS_TRIES
parallel -j "${CONF_USE_OF_CORES}" 'check {#} {}' ::: ${BLOCKLISTS}

# Initialize the counters
INVALID=$(grep -c 'I' "${COUNT_FILE}" || true)
PASSED=$(grep -c 'P' "${COUNT_FILE}" || true)
FAILED=$(grep -c 'F' "${COUNT_FILE}" || true)
ALLOW=$(grep -c 'W' "${COUNT_FILE}" || true)


# Print results
if [[ "${OUTPUT_FORMAT}" == "json" ]]; then
    printf '{"target":"%s","target_type":"%s","ip":"%s",' "${TARGET}" "${TARGET_TYPE}" "${IP}"
    printf '"summary":{"tested":%d,"passed":%d,"allowlisted":%d,"invalid":%d,"blocklisted":%d},' \
        "${COUNT}" "${PASSED}" "${ALLOW}" "${INVALID}" "${FAILED}"
    printf '"results":['
    if [[ -s "${JSON_FILE}" ]]; then
        # Join JSONL lines with commas
        paste -sd',' "${JSON_FILE}"
    fi
    printf ']}\n'
elif [[ "${VERBOSE}" -ge 0 ]]; then
    if [[ -z "${PLAIN}" ]]; then
        printf "\r                                                    \n"
    else
        printf "                                                     \n"
    fi
    echo "----------------------------------------------------------"
    echo Results for "${TARGET}"
    echo
    printf "%-15s" "Tested:";   echo "${COUNT}"
    printf "%-15s" "Passed:";   echo "${GREEN}${PASSED}${CLEAR}"
    printf "%-15s" "Allowlisted:";  echo "${GREEN}${ALLOW}${CLEAR}"
    printf "%-15s" "Invalid:";  echo "${YELLOW}${INVALID}${CLEAR}"
    printf "%-15s" "Blocklisted:";  echo "${RED}${FAILED}${CLEAR}"
    echo "----------------------------------------------------------"
fi

cleanup

if [[ "${FAILED}" -gt 0 ]]; then
    if [[ "${VERBOSE}" -eq -1 ]]; then
        echo "${FAILED}"
    fi
    exit $(( FAILED > 125 ? 125 : FAILED ))
fi

# vim: tabstop=4: shiftwidth=4: expandtab:
